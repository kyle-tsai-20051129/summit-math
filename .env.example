# Copy this file to .env and fill in values from your LiveKit Cloud project.
# Do not commit .env because it contains secrets.

LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret
LIVEKIT_URL=wss://your-project.livekit.cloud
# Optional local SQLite database path for persistent room settings.
ROOM_DATABASE_PATH=data/summit-video.db
# Empty rooms are removed with their saved access settings after this many inactive hours.
ROOM_EMPTY_TTL_HOURS=24
# Token requests are limited per IP address in the running application process.
TOKEN_RATE_LIMIT_MAX_REQUESTS=20
TOKEN_RATE_LIMIT_WINDOW_SECONDS=60
# Incorrect password attempts are limited per IP address and room.
PASSWORD_RATE_LIMIT_MAX_REQUESTS=5
PASSWORD_RATE_LIMIT_WINDOW_SECONDS=900
# Private S3-compatible storage for host-uploaded lesson PDFs.
LESSON_S3_BUCKET=your-private-bucket
LESSON_S3_REGION=us-east-1
LESSON_S3_ENDPOINT=
LESSON_S3_ACCESS_KEY_ID=your_access_key
LESSON_S3_SECRET_ACCESS_KEY=your_secret_key
# Set true for providers requiring path-style URLs, such as many local S3 emulators.
LESSON_S3_FORCE_PATH_STYLE=false
# Development only: when S3 is not configured, PDFs are stored locally here.
# Production deployments require the private S3-compatible storage variables above.
LESSON_LOCAL_STORAGE_PATH=data/lesson-uploads
